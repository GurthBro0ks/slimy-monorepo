# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Database (MySQL via Docker slimy-mysql on NUC1)
DB_HOST=127.0.0.1
DB_USER=user
DB_PASSWORD=password
DB_NAME=slimy
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# AI Providers
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_api_key_here
CHAT_MODEL=gpt-4o
VISION_MODEL=gpt-4o
IMAGE_MODEL=dall-e-3

# Feature Flags
FEATURE_CODES=true
FEATURE_SNAIL_AUTO_DETECT=true

# Snail Auto-Detect (role + channel gating)
SNAIL_ALLOWED_ROLE_IDS=role_id_1,role_id_2
SNAIL_AUTO_DETECT_CHANNEL_IDS=channel_id_1,channel_id_2
SNAIL_CODES_CHANNEL_ID=channel_id_here

# Club Configuration
CLUB_ROLE_ID=club_role_id_here
CLUB_QA_SUSPICIOUS_JUMP_PCT=50
CLUB_USE_ENSEMBLE=false
CLUB_VISION_ENSEMBLE_A=model_a
CLUB_VISION_ENSEMBLE_B=model_b
CLUB_VISION_MODEL=gpt-4o
CLUB_VISION_STRICT_MODEL=gpt-4o
CLUB_VISION_MAX_RETRIES=3
CLUB_VISION_RETRY_BASE_DELAY_MS=1000
CLUB_VISION_RETRY_JITTER_MS=200
CLUB_WEEK_ANCHOR_DAY=monday
CLUB_WEEK_ANCHOR_TIME=00:00
CLUB_WEEK_ANCHOR_TZ=UTC

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=spreadsheet_id_here
GOOGLE_SHEETS_FOLDER_ID=folder_id_here
CLUB_SHEET_URL=https://docs.google.com/spreadsheets/d/yoursheetid

# Alerts
CODES_ALERT_CHANNEL_ID=channel_id_here
CODES_ALERT_ROLE_ID=role_id_here
CODES_ALERT_FALLBACK=channel_id_fallback
ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# Trading Bot
TRADING_BOT_API=http://localhost:8510

# Health & Logging
HEALTH_PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Memory / Persona
MEMORY_DEBUG=false
SLIMY_MEMORY_DIR=/tmp/slimy-memory
SLIMY_MEMORY_FILE=memory.json

# MCP
SCRAPE_CRON=0 */6 * * *
REDIS_URL=redis://localhost:6379
