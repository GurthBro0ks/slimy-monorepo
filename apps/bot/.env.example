# SlimyAI Discord Bot — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Discord
# ============================================================
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_TOKEN=your_discord_bot_token_here

# Legacy (older deployments may use this name)
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================
# AI Provider Configuration (OpenAI)
# Switch providers by changing AI_BASE_URL:
#   Z.AI:    https://api.z.ai/api/paas/v4
#   OpenAI:  https://api.openai.com/v1
#   Ollama:  http://localhost:11434/v1
# ============================================================
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_ai_api_key_here
CHAT_MODEL=gpt-4o
VISION_MODEL=gpt-4o
IMAGE_MODEL=dall-e-3

# Legacy OpenAI (kept for compatibility)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================================
# Anthropic
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================================
# Gemini (for club-vision)
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Club Vision
CLUB_VISION_MODEL=gemini-pro
CLUB_VISION_STRICT_MODEL=gemini-pro
CLUB_VISION_MAX_RETRIES=3
CLUB_VISION_RETRY_BASE_DELAY_MS=1000
CLUB_VISION_RETRY_JITTER_MS=500
CLUB_VISION_ENSEMBLE_A=your_ensemble_model_a
CLUB_VISION_ENSEMBLE_B=your_ensemble_model_b

# ============================================================
# Roster OCR (dual-model: Gemini 2.5 Flash + GLM-4.6V via Z.AI)
# Primary: Gemini 2.5 Flash | Secondary: GLM-4.6V (different model family)
# ============================================================
# GLM model ID on Z.AI. Default: glm-4.6v (GLM-4.6 Vision).
# IMPORTANT: Z.AI API key must be valid. If GLM returns 401 (key expired),
# pipeline fails loudly — no silent fallback to GPT-4o.
ROSTER_OCR_GLM_MODEL=glm-4.6v

# Z.AI API key (for GLM calls).
# If this key is expired (401), GLM calls will fail with explicit error.
ROSTER_OCR_GLM_API_KEY=your_zai_api_key_here

# Z.AI base URL (defaults to https://api.z.ai/api/paas/v4)
ROSTER_OCR_ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Set to "1" to skip live OCR calls in tests/integration
SKIP_LIVE_OCR=

# ============================================================
# MySQL Database
# ============================================================
DB_HOST=127.0.0.1
DB_USER=user
DB_PASSWORD=password
DB_NAME=slimy
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# ============================================================
# Features
# ============================================================
FEATURE_CODES=true
FEATURE_SNAIL_AUTO_DETECT=true

# Snail feature access control
# Roles: Admin (1178129227321712701), Managers (1216250443257217124)
SNAIL_ALLOWED_ROLE_IDS=1178129227321712701,1216250443257217124
# Channels for image analysis
SNAIL_AUTO_DETECT_CHANNEL_IDS=1424143671724343388,1424734430832099439
# Channel for snail code pings
SNAIL_CODES_CHANNEL_ID=1485854165229109268

# Club
DISCORD_GUILD_ID=your_guild_id_here
CLUB_ROLE_ID=your_club_role_id_here
CLUB_QA_SUSPICIOUS_JUMP_PCT=20
CLUB_USE_ENSEMBLE=false
CLUB_WEEK_ANCHOR_DAY=monday
CLUB_WEEK_ANCHOR_TIME=00:00
CLUB_WEEK_ANCHOR_TZ=UTC

# Club Sheets
CLUB_SHEET_URL=https://docs.google.com/spreadsheets/d/yoursheetid
GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEETS_CREDENTIALS=path/to/credentials.json
GOOGLE_SHEETS_FOLDER_ID=your_folder_id
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_TAB_LATEST=Latest
SHEETS_PARENT_FOLDER_ID=your_parent_folder_id
SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# Read Channel exports
KB_EXPORT_ROOT=/home/slimy/kb/raw/discord-exports
READ_CHANNEL_ROLE_ID=your_read_channel_role_id_here

# Snail Codes alerts
CODES_ALERT_CHANNEL_ID=your_alert_channel_id
CODES_ALERT_ROLE_ID=your_alert_role_id
CODES_ALERT_FALLBACK=your_fallback_channel_id

# Trading bot
TRADING_BOT_API=http://localhost:8510

# Error reporting
ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# Health server
HEALTH_PORT=3000

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Persona/Memory
MEMORY_DEBUG=false
SLIMY_MEMORY_DIR=./memory
SLIMY_MEMORY_FILE=memory.json

# Scheduled sync cron
SCRAPE_CRON=0 */6 * * *

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Farming daily summary
FARMING_CHANNEL=your_farming_channel_id
